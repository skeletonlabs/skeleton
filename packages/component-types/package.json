{
	"name": "@skeletonlabs/component-types",
	"version": "5.0.0-next.7",
	"description": "Component types for Skeleton components",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/skeletonlabs/skeleton.git",
		"directory": "packages/component-types"
	},
	"files": [
		"dist",
		"data"
	],
	"sideEffects": false,
	"scripts": {
		"generate": "node ./src/index.ts",
		"check": "tsc",
		"prepack": "pnpm build && clean-package",
		"postpack": "clean-package restore"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": "./data/*.json"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"clean-package": "catalog:",
		"svelte": "catalog:",
		"tinyglobby": "catalog:",
		"ts-morph": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"@clack/prompts": "catalog:"
	},
	"license": "MIT",
	"type": "module",
	"clean-package": {
		"remove": [
			"scripts",
			"devDependencies",
			"clean-package"
		],
		"replace": {
			"exports": {
				".": {
					"types": "./dist/index.d.mts",
					"import": "./dist/index.mjs"
				},
				"./*": "./data/*.json"
			}
		}
	}
}
