{
  "name": "popover",
  "types": [
    {
      "name": "PopoverRootProps",
      "props": [
        {
          "name": "translations",
          "type": "IntlTranslations | undefined",
          "typeKind": "object",
          "optional": true,
          "JSDoc": {
            "description": "Specifies the localized strings that identifies the accessibility elements and their states",
            "tags": []
          }
        },
        {
          "name": "ids",
          "type": "Partial<{ anchor: string; trigger: string | ((value?: string | undefined) => string); content: string; title: string; description: string; closeTrigger: string; positioner: string; arrow: string; }> | undefined",
          "typeKind": "object",
          "optional": true,
          "JSDoc": {
            "description": "The ids of the elements in the popover. Useful for composition.",
            "tags": []
          }
        },
        {
          "name": "modal",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether the popover should be modal. When set to `true`:\n- interaction with outside elements will be disabled\n- only popover content will be visible to screen readers\n- scrolling is blocked\n- focus is trapped within the popover",
            "tags": [
              {
                "name": "default",
                "value": "false"
              }
            ]
          }
        },
        {
          "name": "portalled",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether the popover is portalled. This will proxy the tabbing behavior regardless of the DOM position\nof the popover content.",
            "tags": [
              {
                "name": "default",
                "value": "true"
              }
            ]
          }
        },
        {
          "name": "autoFocus",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether to automatically set focus on the first focusable\ncontent within the popover when opened.",
            "tags": [
              {
                "name": "default",
                "value": "true"
              }
            ]
          }
        },
        {
          "name": "initialFocusEl",
          "type": "(() => HTMLElement | null) | undefined",
          "typeKind": "function",
          "optional": true,
          "JSDoc": {
            "description": "The element to focus on when the popover is opened.",
            "tags": []
          }
        },
        {
          "name": "finalFocusEl",
          "type": "(() => MaybeElement) | undefined",
          "typeKind": "function",
          "optional": true,
          "JSDoc": {
            "description": "Element to receive focus when the popover is closed.",
            "tags": []
          }
        },
        {
          "name": "restoreFocus",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether to restore focus to the element that had focus before the popover was opened.",
            "tags": [
              {
                "name": "default",
                "value": "true"
              }
            ]
          }
        },
        {
          "name": "closeOnInteractOutside",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether to close the popover when the user clicks outside of the popover.",
            "tags": [
              {
                "name": "default",
                "value": "true"
              }
            ]
          }
        },
        {
          "name": "closeOnEscape",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "Whether to close the popover when the escape key is pressed.",
            "tags": [
              {
                "name": "default",
                "value": "true"
              }
            ]
          }
        },
        {
          "name": "onOpenChange",
          "type": "((details: OpenChangeDetails) => void) | undefined",
          "typeKind": "function",
          "optional": true,
          "JSDoc": {
            "description": "Function invoked when the popover opens or closes",
            "tags": []
          }
        },
        {
          "name": "positioning",
          "type": "PositioningOptions | undefined",
          "typeKind": "object",
          "optional": true,
          "JSDoc": {
            "description": "The user provided options used to position the popover content",
            "tags": []
          }
        },
        {
          "name": "open",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "The controlled open state of the popover",
            "tags": []
          }
        },
        {
          "name": "defaultOpen",
          "type": "boolean | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
            "description": "The initial open state of the popover when rendered.\nUse when you don't need to control the open state of the popover.",
            "tags": []
          }
        },
        {
          "name": "triggerValue",
          "type": "string | null | undefined",
          "typeKind": "primitive",
          "optional": true,
          "JSDoc": {
