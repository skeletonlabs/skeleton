{
	"name": "@skeletonlabs/plus.skeleton.dev",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"env:start": "docker compose up -d",
		"env:status": "docker compose ps",
		"env:stop": "docker compose down",
		"env:remove": "docker compose down --rmi all --volumes",
		"drizzle:push": "drizzle-kit push",
		"drizzle:generate": "drizzle-kit generate",
		"drizzle:studio": "drizzle-kit studio --config ./drizzle.config.ts",
		"vercel:prepare": "bash ./scripts/init-git-submodules.sh",
		"screenshots": "node scripts/screenshots.js",
		"postinstall": "svelte-kit sync"
	},
	"devDependencies": {
		"@comark/svelte": "^0.3.1",
		"@iconify-json/simple-icons": "catalog:",
		"@lucide/svelte": "catalog:",
		"@neondatabase/serverless": "catalog:",
		"@shikijs/core": "catalog:",
		"@shikijs/engine-javascript": "catalog:",
		"@shikijs/langs": "catalog:",
		"@shikijs/themes": "catalog:",
		"@shikijs/types": "catalog:",
		"@skeletonlabs/skeleton": "workspace:*",
		"@skeletonlabs/skeleton-svelte": "workspace:*",
		"@sveltejs/adapter-vercel": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/forms": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"better-auth": "catalog:",
		"drizzle-kit": "catalog:",
		"drizzle-orm": "catalog:",
		"lightningcss": "catalog:",
		"neverthrow": "catalog:",
		"playwright": "catalog:",
		"postgres": "catalog:",
		"sharp": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"unplugin-icons": "catalog:",
		"valibot": "catalog:",
		"vite": "catalog:"
	},
	"type": "module"
}
