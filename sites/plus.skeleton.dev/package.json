{
	"name": "@skeletonlabs/plus.skeleton.dev",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"env:start": "docker compose -f ./docker/compose.dev.yaml up -d",
		"env:stop": "docker compose -f ./docker/compose.dev.yaml down",
		"drizzle:push": "drizzle-kit push --config ./drizzle.config.ts",
		"drizzle:generate": "drizzle-kit generate --config ./drizzle.config.ts",
		"drizzle:studio": "drizzle-kit studio --config ./drizzle.config.ts",
		"postinstall": "svelte-kit sync"
	},
	"devDependencies": {
		"@better-auth/drizzle-adapter": "catalog:",
		"@iconify-json/logos": "catalog:",
		"@neondatabase/serverless": "catalog:",
		"@skeletonlabs/skeleton": "workspace:*",
		"@skeletonlabs/skeleton-svelte": "workspace:*",
		"@sveltejs/adapter-vercel": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/forms": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"better-auth": "catalog:",
		"drizzle-kit": "catalog:",
		"drizzle-orm": "catalog:",
		"postgres": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"unplugin-icons": "catalog:",
		"valibot": "catalog:",
		"vite": "catalog:"
	},
	"type": "module"
}
