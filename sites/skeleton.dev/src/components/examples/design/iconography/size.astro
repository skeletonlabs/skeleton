---
import { HeartIcon } from 'lucide-react';
---

<div class="flex flex-col md:flex-row items-center gap-4">
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-xs stroke-0 fill-current" />
		<span class="badge preset-tonal">8px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-sm" />
		<span class="badge preset-tonal">16px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-base" />
		<span class="badge preset-filled">24px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-lg" />
		<span class="badge preset-tonal">32px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-xl" />
		<span class="badge preset-tonal">64px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-2xl" />
		<span class="badge preset-tonal">96px</span>
	</div>
	<div class="flex flex-col items-center gap-2">
		<HeartIcon className="icon-3xl" />
		<span class="badge preset-tonal">128px</span>
	</div>
</div>
