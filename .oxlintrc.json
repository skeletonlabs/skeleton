{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "react", "react-perf", "oxc", "import"],
	"categories": {
		"correctness": "error"
	},
	"ignorePatterns": ["**/database.types.ts"],
	"overrides": [
		{
			"files": ["*.svelte"],
			"rules": {
				"no-unassigned-vars": "off"
			}
		}
	]
}
